{
  "name": "immich-kiosk",
  "version": "0.27.0",
  "description": "",
  "main": "src/kiosk.ts",
  "scripts": {
    "lint": "biome lint --write",
    "js": "esbuild 'src/ts/kiosk.ts' --format=iife --global-name=kiosk --bundle --minify --target=es6 --outfile=./public/assets/js/kiosk.js",
    "css": "esbuild --bundle --loader:.css=css --external:*.woff --external:*.woff2 --external:*.ttf 'src/css/kiosk.css' --outfile=./public/assets/css/kiosk.css && npm run css:postcss",
    "css:postcss": "postcss ./public/assets/css/kiosk.css --no-map -o ./public/assets/css/kiosk.css",
    "build": "npm run css & npm run js & npm run url-builder && wait",
    "url-builder": "esbuild 'src/ts/url-builder.ts' --format=iife --global-name=urlBuilder --bundle --minify --target=es6 --outfile=./public/assets/js/url-builder.js",
    "test": "tsc --noEmit"
  },
  "keywords": [],
  "author": "Damon Golding",
  "license": "AGPL-3.0-only",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24"
    },
    "packageManager": {
      "name": "npm"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "autoprefixer": "^10.5.0",
    "choices.js": "^11.2.3",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.2",
    "esbuild": "^0.28.0",
    "htmx.org": "^2.0.10",
    "postcss": "^8.5.14",
    "postcss-cli": "^11.0.1",
    "postcss-nested": "^7.0.2",
    "typescript": "^6.0.0"
  },
  "browserslist": [
    "chrome >= 106",
    "edge >= 106",
    "opera >= 92",
    "samsung >= 19",
    "and_chr >= 106",
    "firefox >= 107",
    "safari >= 16.1"
  ]
}
